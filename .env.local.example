# Copy to .env.local and fill with the 4Pie Labs Supabase project values.
# .env.local is gitignored — NEVER commit real values.

# --- App runtime (spec §7) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server only — never expose to the browser
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # prod URL on Vercel: https://portal.fourpielabs.com

# --- Notification emails (4d — Resend HTTP API). Optional locally: if unset,
#     notification emails are a logged no-op (the app still works). Use the SAME
#     Resend API key as the auth SMTP (see LAUNCH.md §3b). ---
RESEND_API_KEY=
# RESEND_FROM="4Pie Labs <noreply@mail.fourpielabs.com>"   # optional; this is the default

# --- Cal.com booking webhook (booking sync, Part A) ---
# Shared secret for verifying inbound Cal.com webhook signatures (HMAC-SHA256 over
# the raw body, hex, in the `x-cal-signature-256` header). Set the SAME value here
# and in the Cal.com webhook config (Settings → Developer → Webhooks). Missing →
# the /api/cal/webhook route rejects every request (500). Server-only; never
# NEXT_PUBLIC. Generate one with e.g. `openssl rand -hex 32`.
CAL_WEBHOOK_SECRET=

# --- Tooling (not read by the app; used by Supabase CLI + MCP) ---
# Set these in your shell environment (not committed). SUPABASE_ACCESS_TOKEN
# powers `supabase link` and the Supabase MCP server in .mcp.json.
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=
